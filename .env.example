# MongoDB Atlas
MONGO_URI=mongodb+srv://feastfleet_admin:PASSWORD@feastfleet-cluster.xxxxx.mongodb.net

# Redis
REDIS_URL=rediss://default:xxxxx@eu1-xxxx.upstash.io:6379

# JWT
JWT_SECRET=generate-a-64-char-random-string-here
JWT_REFRESH_SECRET=generate-another-64-char-random-string-here

# Service Ports
GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
MENU_SERVICE_PORT=3002
ORDER_SERVICE_PORT=3003
DELIVERY_SERVICE_PORT=3004
NOTIFICATION_SERVICE_PORT=3005

# Service URLs (for inter-service communication in development)
AUTH_SERVICE_URL=http://localhost:3001
MENU_SERVICE_URL=http://localhost:3002
ORDER_SERVICE_URL=http://localhost:3003
DELIVERY_SERVICE_URL=http://localhost:3004

# Mailtrap SMTP
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_pass
SMTP_FROM=noreply@feastfleet.com

# Stripe (placeholder)
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# Environment
NODE_ENV=development
